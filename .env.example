# LLM Configuration
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-flash
LLM_TEMPERATURE=0.7

# Vision (Multi-modal) Configuration — for image resume parsing
# Falls back to LLM_API_KEY / LLM_BASE_URL if not set
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=qwen-vl-plus

# Embedding Configuration
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
MEMORY_DB_PATH=./memory_data/memory.db
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# Server
HOST=0.0.0.0
PORT=8000
API_HOST_PORT=8000
WEB_PORT=80
DEBUG=false
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://localhost

# Optional public-trial gate. Leave empty for local development.
APP_ACCESS_TOKEN=

# Redis runtime enhancement layer. Keep disabled for plain local Python runs;
# docker-compose overrides these two values to use the included Redis service.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=3
RATE_LIMIT_START_PER_MINUTE=3
RATE_LIMIT_ANSWER_PER_MINUTE=20
RATE_LIMIT_RESUME_PER_HOUR=10
RATE_LIMIT_VISION_PER_DAY=5
REDIS_LOCK_TTL_MS=60000
SESSION_CACHE_TTL_SECONDS=86400
REPORT_CACHE_TTL_SECONDS=604800
WS_PRESENCE_TTL_SECONDS=90

# React/Vite build-time variables for the web container.
# Use /api when the frontend is served by the included Nginx container.
VITE_API_BASE_URL=/api
VITE_ACCESS_CODE=
